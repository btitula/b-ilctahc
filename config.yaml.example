# ~/.config/chatgpt-cli/config.yaml
# ─────────────────────────────────────────────────────
# ChatGPT CLI Configuration
# chmod 600 this file after setting your API key!
# ─────────────────────────────────────────────────────

openai:
  api_key: "sk-your-key-here"   # ← replace this
  model: "gpt-4o"               # gpt-4o | gpt-4-turbo | gpt-3.5-turbo
  max_tokens: 2048
  temperature: 0.7              # 0.0 = deterministic, 1.0 = creative

defaults:
  project: "default"            # project used when none specified
  history_limit: 20             # max messages kept per project (each turn = 2)
  stream: true                  # stream tokens as they arrive

display:
  markdown: true                # render markdown (only when stream: false)
  show_project_header: true     # show project panel above response
  show_timestamp: true          # save timestamps in history

# ─────────────────────────────────────────────────────
# Custom projects live in: ~/.config/chatgpt-cli/projects/
# Create <name>.yaml with keys: description, system_prompt
# Example: ~/.config/chatgpt-cli/projects/terraform.yaml
#
#   description: "Terraform / IaC expert"
#   system_prompt: |
#     You are a Terraform and IaC expert. Provide HCL examples,
#     module structure advice, and state management best practices.
#     Focus on AWS provider. Always include variable definitions.
# ─────────────────────────────────────────────────────
